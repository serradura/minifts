      { "id": 10, "title": "alpha beta", "text": "gamma delta" },
      { "id": 11, "title": "beta gamma", "text": "delta epsilon" }
    ],
    "queries": ["beta", "delta", { "q": "gamma", "opts": {} }]
  },
  {
    "name": "custom_id_field",
