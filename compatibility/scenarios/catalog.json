    "queries": ["quick", "brown", "fox"]
  },
  {
    "name": "basic_multi_field",
    "description": "Two indexed fields, a couple stored. The canonical README example.",
    "options": { "fields": ["title", "text"], "storeFields": ["title", "category"] },
    "documents": [
      { "id": 1, "title": "Moby Dick", "text": "Call me Ishmael", "category": "fiction" },
      { "id": 2, "title": "Zen and the Art of Motorcycle Maintenance", "text": "I can see by my watch", "category": "fiction" },
      { "id": 3, "title": "Neuromancer", "text": "The sky above the port was", "category": "sci-fi" },
      { "id": 4, "title": "Zen and the Art of Archery", "text": "At first sight it must seem", "category": "non-fiction" }
    ],
    "queries": ["zen", { "q": "zen art motorcycle", "opts": {} }, "archery"]
  },
  {
    "name": "all_fields_stored",
    "description": "Every field is both indexed and stored.",
    "options": { "fields": ["title", "author"], "storeFields": ["title", "author", "year"] },
