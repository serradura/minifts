  {
    "name": "combination_tree",
    "description": "A nested combination-tree query (AND of a term and an OR of terms).",
    "options": { "fields": ["text"], "storeFields": ["text"] },
    "documents": [
      { "id": 1, "text": "zen archery" },
      { "id": 2, "text": "zen motorcycle" },
      { "id": 3, "text": "archery and motorcycle" }
    ],
    "queries": [
      { "tree": { "combineWith": "AND", "queries": ["zen", { "combineWith": "OR", "queries": ["motorcycle", "archery"] }] } }
    ]
  },
  {
    "name": "wildcard_match",
